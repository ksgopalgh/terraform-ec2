# Per-user override template
# Copy to: tfvars/<your-name>.tfvars and update values.

# If your VPN/public IP changes, update only this file and re-apply.
instances = {
  windows01 = {
    access_mode       = "both"                 # ssm | rdp | both
    rdp_allowed_cidrs = ["64.103.240.121/32"] # replace with your current IP

    # Keep true to auto-create a key pair for this instance.
    create_key_pair = true

    # Keep true to always allocate a new EIP for this instance.
    create_eip = true

    # Optional: use an existing key pair instead of managed key pair.
    # create_key_pair = false
    # key_pair_name   = "ExistingTeamKeyPairName"
  }
}
